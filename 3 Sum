brute force apporach
class Solution(object):
    def threeSum(self, nums):
        n=len(nums)
        ans=[]
        target=0
        for i in range(0,n-2):                                      #T.c:O(N^3)
            for j in range(i+1,n-1):                                #s.c:O(1)
                for k in range(j+1,n):
                    if (nums[i]+nums[j]+nums[k]==target):
                        triplet=sorted([nums[i],nums[j],nums[k]])
                        if(triplet not in ans):
                            ans.append(triplet)
        return ans

inorder to handle duplicates we are using sort() method so that triplet is sorted and we check that triplet is present in the ans or not
